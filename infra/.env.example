# ── Core secrets ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme_strong_password
HMAC_ROTATION_SECRET=changeme_64_char_hex_string
DASHBOARD_TOKEN=changeme_generate_with_openssl_rand_hex_32

# ── Nginx domain routing ──────────────────────────────────────────────────────
# Point these four DNS A records at this server's IP, then set them here.
AUTHORITY_DOMAIN=license.yourdomain.com
DASHBOARD_DOMAIN=dashboard.yourdomain.com
PACKAGES_DOMAIN=packages.yourdomain.com
NPM_DOMAIN=npm.yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Must include the dashboard origin so the browser allows API calls.
CORS_ORIGINS=https://dashboard.yourdomain.com

# ── Dashboard API URL (baked into the Docker build) ──────────────────────────
VITE_API_URL=https://license.yourdomain.com

# ── Verdaccio ─────────────────────────────────────────────────────────────────
# Admin account created on first boot. Change before going live.
# After changing: docker compose run --rm verdaccio-init
VERDACCIO_ADMIN_PASSWORD=changeme_generate_strong_password

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Required for invoicing and renewal emails. Leave blank to disable.
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=billing@yourdomain.com
SMTP_PASSWORD=changeme_smtp_password
SMTP_FROM=billing@yourdomain.com
SMTP_FROM_NAME=Zen License Platform
DEFAULT_CURRENCY=ZAR

# ── PayFast (primary gateway — ZAR only) ─────────────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=false

# ── PayPal (international) ────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_SANDBOX=false
